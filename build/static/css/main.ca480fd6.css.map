.AICTEVAANI_container {
    padding: 1rem;
    height: 100vh;
  }
  
  .AICTEVAANI_align {
    margin-bottom: 2rem;
  }
  
  .AICTEVAANI_Header_container {
    width: 100%;
    font-size: 22px;
    font-weight: 500;
    display: flex;
    align-items: center;
    gap: 2rem;
  }
  
  .AICTEVAANI_wrapper {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    gap: 1rem;
  }
  
  .AICTEVAANI_body {
    display: flex;
    width: 100%;
    justify-content: space-between;
  }
  
  .AICTEVAANI_main {
    background-color: rgb(230, 255, 247);
    width: 79%;
    height: 100vh;
    padding-bottom: 2rem;
    display: flex;
    flex-direction: column;
    justify-content: space-between;
    overflow-y: scroll;
  }
  
  .AICTEVAANI_right {
    width: 25%;
    height: 100vh;
    overflow-y: scroll;
  }
  
  .AICTEVAANI_text_box {
    margin-top: 1rem;
    margin-left: 2rem;
    display: flex;
    flex-direction: column;
    gap: 0.6rem;
    list-style: decimal;
  }
  
  .AICTEVAANI_text_box a {
    color: #5ca20d;
    margin-left: 1rem;
    font-size: 14px;
    font-weight: 500;
  }
  
  .AICTEVAANI_text_box h2 {
    margin-top: 1rem;
    font-size: 18px;
    font-weight: 500;
  }
  
  .AICTEVAANI_Header {
    font-size: 26px;
    color: #5091b2;
    background-color: #e9f7fe;
    border: 1px solid #b6d7e8;
    font-family: Arial, sans-serif;
    margin-bottom: 15px;
    padding: 14px 40px 14px 18px;
    box-shadow: 0px 1px 1px 0px rgba(180, 180, 180, 0.1);
  }
  
  