/* hostel_administration.css - A modern, enchanting design for the Hostel page */

/* 1. FONT IMPORT & ROOT VARIABLES */
@import url('https://fonts.googleapis.com/css2?family=Roboto:wght@400;500;700&display=swap');

:root {
  --font-family-base: 'Roboto', sans-serif;
  --bg-page: #f4f5f7;
  --bg-card: #ffffff;
  --text-primary: #2d3748;
  --text-secondary: #718096;
  --accent-color: #0056b3;
  --border-color: #e2e8f0;
  --boys-hostel-bg: #e3f2fd;  /* Light Blue */
  --boys-hostel-icon: #1e88e5; /* Stronger Blue */
  --girls-hostel-bg: #fce4ec; /* Light Pink */
  --girls-hostel-icon: #d81b60;/* Stronger Pink */
  --shadow-color: rgba(45, 55, 72, 0.1);
}

/* 2. UNIVERSAL CONTAINER & PAGE LAYOUT */
.container {
  width: 90%;
  max-width: 1280px;
  margin-left: auto;
  margin-right: auto;
}

.page-container {
  background-color: var(--bg-page);
  font-family: var(--font-family-base);
}

.main-content {
  width: 100%;
  padding-top: 1.5rem;
  padding-bottom: 1.5rem;
}

/* 3. BASE & MOBILE STYLES */
.page-layout-wrapper {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

.primary-content-card {
  background-color: var(--bg-card);
  border-radius: 16px;
  padding: 1.5rem;
  box-shadow: 0 4px 20px var(--shadow-color);
}

.primary-content-card h2 {
  font-size: 1.5rem;
  font-weight: 700;
  color: var(--text-primary);
  margin: 0 0 1rem 0;
  padding-bottom: 0.75rem;
  border-bottom: 2px solid var(--border-color);
}

.primary-content-card p {
  font-size: 1rem;
  line-height: 1.7;
  color: var(--text-secondary);
  margin: 0 0 1rem 0;
}

.sidebar-content {
  display: flex;
  flex-direction: column;
  gap: 1.5rem;
}

/* 4. WARDEN CARDS STYLING (The enchanting part!) */
.warden-cards-container {
  margin-top: 2rem;
  display: grid;
  grid-template-columns: 1fr; /* A single column on mobile */
  gap: 1.5rem;
}

.warden-card {
  background: #fff;
  border: 1px solid var(--border-color);
  border-radius: 12px;
  padding: 1.5rem;
  text-align: center;
  transition: transform 0.3s ease, box-shadow 0.3s ease;
}

.warden-card:hover {
  transform: translateY(-5px);
  box-shadow: 0 8px 25px rgba(45, 55, 72, 0.12);
}

.warden-card__icon-bg {
  margin: 0 auto 1rem auto;
  width: 70px;
  height: 70px;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
}

.warden-card__icon-bg.boys-hostel {
  background-color: var(--boys-hostel-bg);
  color: var(--boys-hostel-icon);
}

.warden-card__icon-bg.girls-hostel {
  background-color: var(--girls-hostel-bg);
  color: var(--girls-hostel-icon);
}

.warden-card__name {
  font-size: 1.25rem;
  font-weight: 700;
  color: var(--text-primary);
  margin: 0 0 0.25rem 0;
}

.warden-card__department {
  font-size: 0.9rem;
  color: var(--text-secondary);
  margin: 0 0 0.75rem 0;
}

.warden-card__role {
  font-size: 1rem;
  font-weight: 500;
  color: var(--accent-color);
  margin: 0;
}


/* 5. TABLET & DESKTOP STYLES (Progressive Enhancement) */
@media (min-width: 768px) {
  .main-content { padding-top: 2.5rem; padding-bottom: 2.5rem; }
  .page-layout-wrapper { flex-direction: row; gap: 2.5rem; }
  .primary-content-card { flex: 3; padding: 2rem; }
  .sidebar-content { flex: 1; min-width: 280px; }
  .primary-content-card h2 { font-size: 1.75rem; }

  /* Switch to a two-column grid for the warden cards */
  .warden-cards-container {
    grid-template-columns: 1fr 1fr;
  }
}